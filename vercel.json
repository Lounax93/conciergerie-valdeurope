{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/:slug((?!blog|assets|styles|qui-sommes-nous|robots\\.txt|sitemap\\.xml|favicon\\.ico|vercel\\.json).*)", "destination": "/blog/:slug", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
