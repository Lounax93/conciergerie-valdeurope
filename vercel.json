{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "redirects": [
    { "source": "/combien-rapporte-airbnb-val-europe", "destination": "/blog/combien-rapporte-airbnb-val-europe", "permanent": true },
    { "source": "/saisonnalite-airbnb-val-europe-disneyland", "destination": "/blog/saisonnalite-airbnb-val-europe-disneyland", "permanent": true }
  ]
}
